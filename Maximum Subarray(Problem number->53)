class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int cursum = 0 ,Maxsum =    INT_MIN;
        for(int val:  nums){
            cursum+=val;
            Maxsum = max(cursum, Maxsum);
            if(cursum < 0){
                cursum = 0;

            }

        }

    return Maxsum;
        
    }
};
