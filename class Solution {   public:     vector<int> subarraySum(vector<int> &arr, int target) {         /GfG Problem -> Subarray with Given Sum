class Solution {
  public:
    vector<int> subarraySum(vector<int> &arr, int target) {
        // code here
    int n = arr.size();
    int sum = 0;
    
    for(int i = 0; i<n-1; i++){
         sum=0;
        for(int j = i; j<n; j++){
                sum+=arr[j];
                if(sum==target){
                    return{i+1,j+1};   
            
                }
                
        }
   
    }
    return {-1};
    }
};
